# Salin file ini ke .env.local lalu isi dari Project Settings > API di dashboard Supabase.
# Selama variabel ini kosong, situs otomatis memakai data fallback di src/lib/data/*.ts
# (lihat src/lib/queries/helpers.ts) — build & halaman publik tetap jalan tanpa Supabase.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hanya dipakai di Server Actions/Route Handlers (Fase 2+ — dashboard admin).
# JANGAN pernah diekspos ke client bundle atau diberi prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Fondasi multi-tenant (Phase 3) — lihat src/lib/tenant/env.ts.
# Semua tenant produksi wajib diakses lewat subdomain sendiri (tidak ada
# fast-path domain default lagi). DEFAULT_TENANT_SLUG hanya dipakai untuk
# tenant mock saat Supabase belum dikonfigurasi.
TENANT_STRATEGY=subdomain
TENANT_BASE_DOMAIN=appdesa.com
DEFAULT_TENANT_SLUG=sita

# Dev-only: simulasikan tenant tertentu tanpa DNS/hosts (lihat resolve-tenant.ts).
TENANT_DEV_FORCE_SLUG=
# Dev/preview-only: echo x-tenant-slug ke response header untuk verifikasi via curl.
TENANT_DEBUG_HEADERS=

# Landlord / Platform Admin Panel — origin absolut aplikasi (BUKAN subdomain
# tenant manapun, karena undangan admin dikirim dari /platform yang tidak
# tenant-scoped). Dipakai sebagai redirectTo undangan email ke /set-password.
# Contoh: http://localhost:3000 (dev) atau https://appdesa.com (produksi).
NEXT_PUBLIC_SITE_URL=
